{
  "name": "nomade-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:country-json": "node --experimental-strip-types scripts/gen-country-json.mjs",
    "gen:quiz-json": "node --experimental-strip-types scripts/gen-quiz-json.mjs",
    "gen:test-vectors": "node scripts/sync-test-vectors.mjs",
    "gen:ios": "npm run gen:country-json && npm run gen:quiz-json && npm run gen:test-vectors"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
